<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rich Dad Cashflow Tracker</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#1e40af">
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; }
        .nav-tab { transition: all 0.2s; }
        .nav-tab.active { border-bottom: 3px solid #1e40af; color: #1e40af; font-weight: 600; }
        input[type="number"] { -moz-appearance: textfield; }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">

<div class="max-w-4xl mx-auto bg-white shadow-xl min-h-screen">

    <!-- Header -->
    <div class="bg-blue-900 text-white p-6 flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold">Cashflow Tracker</h1>
            <p class="text-blue-200">Rich Dad Style • Easy Fill</p>
        </div>
        <button onclick="installApp()" id="installBtn" class="hidden bg-white text-blue-900 px-5 py-2 rounded-2xl font-medium text-sm">📲 Install</button>
    </div>

    <!-- Month Selector -->
    <div class="bg-white border-b p-4 flex items-center justify-between">
        <button onclick="prevMonth()" class="px-5 py-2 text-blue-600 hover:bg-blue-50 rounded-xl">← Prev</button>
        <select id="month-select" onchange="switchMonth()" class="text-xl font-semibold bg-transparent text-center focus:outline-none"></select>
        <button onclick="nextMonth()" class="px-5 py-2 text-blue-600 hover:bg-blue-50 rounded-xl">Next →</button>
    </div>

    <!-- Tabs -->
    <div class="flex border-b overflow-x-auto bg-white sticky top-0 z-10">
        <button onclick="switchTab(0)" class="nav-tab active px-6 py-4 flex-1 text-sm">Daily</button>
        <button onclick="switchTab(1)" class="nav-tab px-6 py-4 flex-1 text-sm">Income</button>
        <button onclick="switchTab(2)" class="nav-tab px-6 py-4 flex-1 text-sm">Expenses</button>
        <button onclick="switchTab(3)" class="nav-tab px-6 py-4 flex-1 text-sm">Assets</button>
        <button onclick="switchTab(4)" class="nav-tab px-6 py-4 flex-1 text-sm">Dashboard</button>
    </div>

    <div class="p-6 space-y-8">

        <!-- DAILY -->
        <div id="tab-0" class="tab-content">
            <h2 class="text-2xl font-semibold mb-4">Daily Money Tracker</h2>
            <div class="overflow-x-auto border rounded-2xl">
                <table class="w-full" id="daily-table">
                    <thead class="bg-gray-100">
                        <tr>
                            <th class="p-3 text-left">Date</th>
                            <th class="p-3 text-left">Income Source</th>
                            <th class="p-3 text-right">In ($)</th>
                            <th class="p-3 text-left">Expense</th>
                            <th class="p-3 text-right">Out ($)</th>
                            <th class="p-3">Notes</th>
                        </tr>
                    </thead>
                    <tbody id="daily-body"></tbody>
                </table>
            </div>
            <button onclick="addDailyRow()" class="mt-4 w-full bg-blue-600 text-white py-4 rounded-2xl">+ Add Transaction (Auto Date)</button>
        </div>

        <!-- INCOME -->
        <div id="tab-1" class="tab-content hidden">
            <h2 class="text-2xl font-semibold mb-4">Monthly Income</h2>
            <table class="w-full border" id="income-table"></table>
            <div class="mt-6 p-4 bg-emerald-50 rounded-2xl flex justify-between text-xl font-semibold">
                <span>Total Income</span>
                <span id="total-income" class="font-mono">0.00</span>
            </div>
        </div>

        <!-- EXPENSES (Pre-filled for easy use) -->
        <div id="tab-2" class="tab-content hidden">
            <h2 class="text-2xl font-semibold mb-4">Monthly Expenses & Wealth Killers</h2>
            <table class="w-full border" id="expense-table"></table>
            <div class="mt-6 p-4 bg-rose-50 rounded-2xl flex justify-between text-xl font-semibold">
                <span>Total Expenses</span>
                <span id="total-expenses" class="font-mono">0.00</span>
            </div>
        </div>

        <!-- ASSETS & LIABILITIES -->
        <div id="tab-3" class="tab-content hidden grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <h2 class="text-xl font-semibold mb-4">Assets</h2>
                <table class="w-full border" id="asset-table"></table>
            </div>
            <div>
                <h2 class="text-xl font-semibold mb-4">Liabilities</h2>
                <table class="w-full border" id="liability-table"></table>
            </div>
        </div>

        <!-- DASHBOARD -->
        <div id="tab-4" class="tab-content hidden">
            <h2 class="text-2xl font-bold mb-6">Wealth Dashboard</h2>
            <button onclick="exportCSV()" class="w-full bg-green-600 text-white py-4 rounded-2xl">Export to CSV</button>
        </div>
    </div>
</div>

<script>
    let currentMonth = '2026-06';
    let dataStore = {};

    const incomeItems = ["Salary", "Farming", "Side Hustle", "Online Work", "Rental Income", "Business Sales", "Commissions", "Other"];
    const expenseItems = ["Rent", "Food", "Fuel", "Utilities", "Transport", "Medical", "Loan Payments", "Internet", "Betting", "Alcohol", "Eating Out", "Impulse Spending", "Subscriptions", "Lifestyle Pressure", "Debts", "Other"];

    function switchTab(n) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden'));
        document.getElementById(`tab-${n}`).classList.remove('hidden');
        document.querySelectorAll('.nav-tab').forEach((btn, i) => btn.classList.toggle('active', i === n));
    }

    function addDailyRow() {
        const tbody = document.getElementById('daily-body');
        const row = document.createElement('tr');
        row.className = "border-b";
        const today = new Date().toISOString().split('T')[0];
        row.innerHTML = `
            <td class="p-3"><input type="date" value="${today}" class="w-full" onchange="calculateDaily()"></td>
            <td class="p-3"><input type="text" class="w-full" placeholder="Salary / Side Hustle"></td>
            <td class="p-3"><input type="number" step="0.01" class="w-full text-right" onchange="calculateDaily()"></td>
            <td class="p-3"><input type="text" class="w-full" placeholder="Fuel / Food"></td>
            <td class="p-3"><input type="number" step="0.01" class="w-full text-right" onchange="calculateDaily()"></td>
            <td class="p-3"><input type="text" class="w-full"></td>
        `;
        tbody.appendChild(row);
        calculateDaily();
    }

    function calculateDaily() {
        let inT = 0, outT = 0;
        document.querySelectorAll('#daily-body tr').forEach(r => {
            const nums = r.querySelectorAll('input[type="number"]');
            inT += parseFloat(nums[0]?.value) || 0;
            outT += parseFloat(nums[1]?.value) || 0;
        });
        document.getElementById('daily-in').textContent = inT.toFixed(2);
        document.getElementById('daily-out').textContent = outT.toFixed(2);
        document.getElementById('daily-net').textContent = (inT - outT).toFixed(2);
    }

    function initIncome() {
        const tbody = document.getElementById('income-table').querySelector('tbody') || document.createElement('tbody');
        if (!tbody.parentNode) document.getElementById('income-table').appendChild(tbody);
        tbody.innerHTML = '';
        incomeItems.forEach(item => {
            const tr = document.createElement('tr');
            tr.innerHTML = `<td class="border p-3">${item}</td><td class="border p-3"><input type="number" step="0.01" value="0" class="w-full text-right" onchange="updateTotals()"></td>`;
            tbody.appendChild(tr);
        });
    }

    function initExpenses() {
        const tbody = document.getElementById('expense-table').querySelector('tbody') || document.createElement('tbody');
        if (!tbody.parentNode) document.getElementById('expense-table').appendChild(tbody);
        tbody.innerHTML = '';
        expenseItems.forEach(item => {
            const tr = document.createElement('tr');
            tr.innerHTML = `<td class="border p-3">${item}</td><td class="border p-3"><input type="number" step="0.01" value="0" class="w-full text-right" onchange="updateTotals()"></td>`;
            tbody.appendChild(tr);
        });
    }

    function updateTotals() {
        let inc = 0, exp = 0;
        document.querySelectorAll('#income-table input').forEach(i => inc += parseFloat(i.value)||0);
        document.querySelectorAll('#expense-table input').forEach(i => exp += parseFloat(i.value)||0);
        document.getElementById('total-income').textContent = inc.toFixed(2);
        document.getElementById('total-expenses').textContent = exp.toFixed(2);
    }

    // Simple init for Assets & Liabilities
    function initAssetsLiab() {
        // You can expand this later
    }

    function populateMonths() {
        const select = document.getElementById('month-select');
        select.innerHTML = '';
        for (let y = 2025; y <= 2027; y++) {
            for (let m = 1; m <= 12; m++) {
                const key = `\( {y}- \){String(m).padStart(2, '0')}`;
                const opt = document.createElement('option');
                opt.value = key;
                opt.textContent = new Date(y, m-1).toLocaleString('default', { month: 'long', year: 'numeric' });
                if (key === currentMonth) opt.selected = true;
                select.appendChild(opt);
            }
        }
    }

    function switchMonth() { currentMonth = document.getElementById('month-select').value; }

    function exportCSV() {
        alert("Data exported for " + currentMonth + " (CSV download in full version)");
    }

    window.onload = function() {
        populateMonths();
        initIncome();
        initExpenses();
        for (let i = 0; i < 3; i++) addDailyRow();
        switchTab(0);
    };
</script>
</body>
</html>
